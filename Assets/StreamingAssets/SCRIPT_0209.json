                    "type": "uiObjective",
                    "text": "Go up to the annex's second floor and gather clues.",
                    "nextScene": "S09_ANNEX_2F"
                }
            ]
        },

        {
            "id": "S09_ANNEX_2F",
            "name": "Part 2 - Annex 2F (Find the Truth)",
            "nodes": [
                {
                    "id": "S09_N0",
                    "type": "pickup",
                    "itemId": "ARREARS_NOTICE"
                },
                {
                    "id": "S09_N1",
                    "type": "pickup",
                    "itemId": "CONSENT_NOTE"
                },
