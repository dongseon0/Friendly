                    "itemId": "MAGAZINE"
                },
                {
                    "id": "S03_N1",
                    "type": "uiObjective",
                    "text": "Head to the corridor",
                    "nextScene": "S04_CORRIDOR"
                }
            ]
        },
        {
            "id": "S04_CORRIDOR",
            "name": "Part 1 - Corridor",
            "nodes": [
                {
                    "id": "S04_N0",
                    "type": "pickup",
                    "itemId": "PROTEST_PHOTO"
                },
                {
                    "id": "S04_N1",
                    "type": "uiObjective",
                    "text": "Head to Dad's private office",
                    "nextScene": "S05_PC_DAD_OFFICE"
                }
            ]
        },
        {
            "id": "S05_PC_DAD_OFFICE",
            "name": "Part 1 - Private Office (My Dad)",
            "nodes": [
                {
                    "id": "S05_N0",
                    "type": "narration",
                    "text": "Let's take a look around {PC_DAD_NAME}'s office."
                },
                {
                    "id": "S05_N1",
                    "type": "pickup",
                    "itemId": "SCHEDULE_SHEET"
                },
                {
                    "id": "S05_N2",
                    "type": "pickup",
                    "itemId": "STICKY_NOTE"
                },
                {
                    "id": "S05_N3",
                    "type": "pickup",
                    "itemId": "NPCDAD_CHART"
                },
                {
                    "id": "S05_N4",
                    "type": "interaction",
                    "target": "Locked Safe",
                    "whenInteract": [
                        {
                        "type": "branch",
                        "conditions": [
                                { "flag": "found_schedule_sheet" },
                                { "flag": "found_sticky_note" },
                                { "flag": "found_npcdad_chart" }
                            ],
                            "then": [
                                {
                                "type": "dialogue",
                                "speaker": "{PC_NAME}",
                                "text": "There was... more of a clue about the safe on the medical chart. But the numbers are missing... I need another hint.",
                                "next": "S05_N5"
                                }
                            ],
                            "else": [
                                {
                                "type": "dialogue",
                                "speaker": "{PC_NAME}",
                                "text": "I should look around the office more before trying the safe.",
                                "next": "S05_N0"
                                }
                            ]
                        }
                    ]
                },
                {
                    "id": "S05_N5",
                    "type": "uiObjective",
                    "text": "Let's head to the CCTV room.",
                    "nextScene": "S06_CCTV_DOOR"
                }
            ]
        },
        {
            "id": "S06_CCTV_DOOR",
            "name": "Part 1 - CCTV Room Door",
            "nodes": [
                {
                    "id": "S06_N0",
                    "type": "interaction",
                    "target": "Keypad",
                    "whenInteract": [
                        {
                            "type": "branch",
                            "conditions": [{ "flag": "found_sticky_note" }],
                            "then": [
                                { "type": "inputCode", "expected": "1296", "onSuccess": "S06_N1", "onFail": "S06_N2", "onCancel": "S06_N3" }
                            ],
                            "else": [
                                {
                                "type": "dialogue",
                                "speaker": "{PC_NAME}",
                                "text": "I can't... remember the number. There was a hint somewhere.",
                                "next": "S06_N3"
                                }
                            ]
                        }
                    ]
                },
                {
                    "id": "S06_N1",
                    "type": "action",
                    "do": [
                        { "type": "setFlag", "flag": "cctv_room_unlocked", "value": true },
                        { "type": "sound", "name": "door_unlock" }
                    ],
                    "nextScene": "S07_CCTV_ROOM"
                },
                {
                    "id": "S06_N2",
                    "type": "dialogue",
                    "speaker": "{PC_NAME}",
                    "text": "...No. That's not it.",
                    "next": "S06_N0"
                },
                {
                    "id": "S06_N3",
                    "type": "dialogue",
                    "speaker": "{PC_NAME}",
                    "text": "Not now. I should look around first.",
                    "nextScene": "S04_CORRIDOR",
                    "nextNode": "S04_N1"
                }
            ]
        },

        {
            "id": "S07_CCTV_ROOM",
            "name": "Transition - CCTV Room",
            "nodes": [
                {
                    "id": "S07_N0",
                    "type": "pickup",
                    "itemId": "DVD_RICH_SURGERY"
                },
                {
                    "id": "S07_N1",
                    "type": "interaction",
                    "target": "{PC_NAME}",
                    "whenInteract": [
                        { "type": "setFlag", "flag": "watched_dvd", "value": true },
                        { "type": "video", "id": "RICH_SURGERY_FOOTAGE" },
                        { "type": "narration", "text": "Date on screen: {PAST_DATE}. Lead surgeon: {PC_DAD_NAME}." },
                        { "type": "sound", "name": "footsteps_slow" },
                        { "type": "narration", "text": "Behind you... the sound of step..." },
                        { "type": "setFlag", "flag": "npc_confronted", "value": true },
                        { "type": "dialogue", "speaker": "{NPC_NAME}", "text": "That... is surgery footage, isn't it?", "next": "S07_N2" }
                    ]
                },
                {
                    "id": "S07_N2",
                    "type": "dialogue",
                    "speaker": "{PC_NAME}",
                    "text": "What the... You scared me. Where did you go?",
                    "next": "S07_N3"
                },
                {
                    "id": "S07_N3",
                    "type": "dialogue",
                    "speaker": "{NPC_NAME}",
                    "text": "Today, fifteen years ago. {PAST_DATE}. The records here say... '{PC_DAD_NAME}' was the surgeon in charge...",
                    "next": "S07_N4"
                },
                {
                    "id": "S07_N4",
                    "type": "choice",
                    "prompt": "Choose a response.",
                    "choices": [
                        {
                            "text": "...Yeah. That's my dad.",
                            "effects": [{ "type": "addVar", "var": "trust_npc", "value": 1 }],
                            "next": "S07_N5"
                        },
                        {
                            "text": "...Why are you asking that?",
                            "effects": [{ "type": "addVar", "var": "trust_npc", "value": 1 }],
                            "next": "S07_N5"
                        }
                    ]
                },
                {
                    "id": "S07_N5",
                    "type": "dialogue",
                    "speaker": "{NPC_NAME}",
                    "text": "There's no denying he was... an incredible surgeon.",
                    "next": "S07_N6"
                },
                {
                    "id": "S07_N6",
                    "type": "dialogue",
                    "speaker": "{NPC_NAME}",
                    "text": "But the patient who was supposed to be operated on that day... was someone else..",
                    "next": "S07_N7"
                },
                {
                    "id": "S07_N7",
                    "type": "dialogue",
                    "speaker": "{NPC_NAME}",
                    "text": "Because he was poor! With no money... he lost his place in the surgery order, and in the end... it cost him his life.",
                    "next": "S07_N8"
                },
                {
                    "id": "S07_N8",
                    "type": "dialogue",
                    "speaker": "{PC_NAME}",
                    "text": "...What are you trying to say, {NPC_FIRSTNAME}.",
                    "next": "S07_N9"
                },
                {
                    "id": "S07_N9",
                    "type": "dialogue",
                    "speaker": "{NPC_NAME}",
                    "text": "And wouldn't you know it... today is my dad's death anniversary. You saw it too. At the ossuary.",
                    "next": "S07_N10"
                },
                {
                    "id": "S07_N10",
                    "type": "action",
                    "do": [
                        { "type": "light", "mode": "redPulse", "intensity": 0.6 },
                        { "type": "sound", "name": "low_rumble" }
                    ],
                    "next": "S07_N11"
                },
                {
                    "id": "S07_N11",
                    "type": "dialogue",
                    "speaker": "{NPC_NAME}",
                    "text": "But you know...? When I see him today... it just broke me.",
                    "next": "S07_N12"
                },
                {
                    "id": "S07_N12",
                    "type": "dialogue",
                    "speaker": "{NPC_NAME}",
                    "text": "{PC_DAD_NAME}. If he had just done his job properly... my dad would still be alive right now.",
                    "next": "S07_N13"
                },
                {
                    "id": "S07_N13",
                    "type": "dialogue",
                    "speaker": "{NPC_NAME}",
                    "text": "When you celebrated your dad's birthday every year, I... I mark the day he died.",
                    "next": "S07_N14"
                },
                {
                    "id": "S07_N14",
                    "type": "dialogue",
                    "speaker": "{NPC_NAME}",
                    "text": "He could've lived longer... he should've lived longer...!",
                    "next": "S07_N15"
                },
                {
                    "id": "S07_N15",
                    "type": "action",
                    "do": [
                        { "type": "setFlag", "flag": "alarm_started", "value": true },
                        { "type": "sound", "name": "alarm_siren" },
                        { "type": "vignette", "mode": "red", "strength": 0.8 },
                        { "type": "setFlag", "flag": "chase_started", "value": true }
                    ],
                    "next": "S07_N16"
                },
                {
                    "id": "S07_N16",
                    "type": "uiObjective",
                    "text": "Get out of here! (Press Shift to run)",
                    "nextScene": "S08_CHASE_ROUTE"
                }
            ]
        },

        {
            "id": "S08_CHASE_ROUTE",
            "name": "Part 2 - Chase / Escape",
            "onEnter": [
                { "type": "narration", "text": "The alarm blares, pounding in your skull. Behind you, a door slams-BANG." }
