    "items":{
        "BUSINESS_CARD": {
            "name" : "Ian's business card",
            "desc" : "Dr. {PC_DAD_NAME} / General Surgeon / call : 0000-000-000-000",
            "onInspectLines": [
                "Oh, it's my dad's."
            ],
            "addFlags": ["found_business_card"],
            "addVar": {"suspicion": 0}
        },
        "MAGAZINE": {
            "name" : "Monthly Doctor",
            "desc" : "Proud of Doctor, {PC_DAD_NAME}, Commended for Emergency Medical Commitment",
            "onInspectLines": [
                "I'm so proud of my dad. I hope to be a doctor like him."
            ],
            "addFlags": [ "found_magazine" ],
            "addVar": {"suspicion": 0}
        },
        "PROTEST_PHOTO": {
            "name" : "protest photo",
            "desc" : "'Give me back my dad! Out of the way, doctor {PC_DAD_NAME}!'",
            "onInspectLines": [
                "{NPC_FIRSTNAME}? No, wait, that's my father!"
            ],
            "addFlags": ["found_protest_photo"],
            "addVar": {"suspicion": 1, "trust_npc": -1}
        },
        "SCHEDULE_SHEET": {
            "name" : "Surgical Scheduler",
            "desc" : "{PAST_DATE} / {NPC_DAD_NAME} -> {RICH_PATIENT_NAME} (Roughly modified with a pen) / Doctor : {PC_DAD_NAME}",
            "onInspectLines": [
                "{NPC_DAD_NAME}...? I've heard this name before...",
                "...Did he change the schedule? Why?"
            ],
            "addFlags": ["found_schedule_sheet"],
            "addVar": {"suspicion": 2}
        },
        "STICKY_NOTE": {
            "name" : "sticky note",
            "desc" : "<b>M</b>M-D<b>D</b>-YY<b>YY</b>... I'm sorry, but it's gonna be good for you, my friend",
            "onInspectLines": [
                "Only a few letters are written in bold...",
                "Apologies... for what?"
            ],
            "addFlags": ["found_sticky_note"],
            "addVar": {"suspicion": 1}
        },
        "NPCDAD_CHART": {
            "name": "Diagnostic Record of Patient {NPC_DAD_NAME}",
            "desc": "Diagonstic record. At the bottom, it is faintly written : 'Security PW needed. Two-digit personal access code + 985 (as the last three digits)'.",
            "onInspectLines": [
                "{NPC_DAD_NAME}... Wait, isn't it the name of {NPC_FIRSTNAME}'s dad?",
                "...It has some hints for security passwords on it. Where's the rest..."
            ],
            "addFlags": ["found_npcdad_chart"],
            "addVar": { "suspicion": 1 }
        },
        "SAFE_MONEY_MEMO": {
            "name": "envelopes and notes",
            "desc": "Cash envelope + note: '{PAST_DATE} / Receipt of subsidy (Source:{RICH_PATIENT_NAME})'",
            "onInspectLines": [
                "Cash...? Did your dad get the money?"
            ],
            "addFlags": ["found_money_memo"],
            "addVar": { "suspicion": 1 }
        },
        "DVD_RICH_SURGERY": {
            "name": "an operating room DVD",
            "desc": "{RICH_PATIENT_NAME} Surgical image recording",
            "onInspectLines": [
                "... Oh, It's my dad's surgery video.",
                "If I look at this... Maybe I can find out what happened."
            ]
        },

        "ARREARS_NOTICE": {
            "name": "a delinquent/unpaid bill",
            "desc": "Nonpayment for hospitalization and surgery. Several memos requesting installment payments.",
            "onInspectLines": [
                "At this point... he probably wanted to give up on the surgery.",
                "Poverty really can... push someone this far."
            ],  
            "addFlags": ["truth_poverty"]
        },
        "CONSENT_NOTE": {
            "name": "Handwritten Note (Patient Signature)",
            "desc": "'I don't want to be a burden to my family anymore. Even knowing the situation, I will go through with the surgery.'",
            "onInspectLines": [
                "It's not that he didn't want the surgery... it's that... he 'didn't want to be a burden'..."
            ],
            "addFlags": ["truth_consent"]
        },
        "PHOTO_BABY": {
            "name": "Photo (Entrance Ceremony)",
            "desc": "{NPC_NAME}'s entrance ceremony. {PC_DAD_NAME} and {NPC_DAD_NAME} are smiling together. It is circled on 1.1 birthday.",
            "onInspectLines": [
                "They look like they completely trusted each other."
            ],
            "addFlags": ["truth_relationship"]
        },
        "CONTRACT": {
            "name": "Sponsorship Agreement (Copy)",
            "desc": "'Party A ({RICH_PATIENT_NAME}) will fully cover the cost of Party B ({NPC_DAD_NAME})'s surgery scheduled for the following day. However, Party A’s surgery will be performed first.”",
            "onInspectLines": [
                "It's a contract.",
                "So this is what Dad meant by 'There's always a way when it comes to money'...",
                "...But because of this priority, it got pushed back by a day, and that one day..."
            ],
            "addFlags": ["truth_contract"]
        },
        "HIPPOCRATIC": {
            "name": "Hippocratic Oath Framed Plaque",
            "desc": "A worn frame. 'The patient's life comes first...'",
            "onInspectLines": [
                "'A doctor is someone who fights to save lives.'",
                "...Did Dad stay that way until the very end?"
            ],
            "addFlags": ["truth_hippocratic"]
        }
    },

    "scenes":[
        {
            "id": "S00_CAR_OUTSIDE",
            "name": "Out of the Car (In Front of the Ossuary / Abandoned Hospital)",
            "onEnter": [
                { "type": "uiObjective", "text": "Let's go to the ossuary." }
            ],
            "nodes": [
                {
                    "id": "S00_N0",
                    "type": "dialogue",
                    "speaker": "{NPC_NAME}",
                    "text": "Here we come. ...Thanks for coming today.",
                    "next": "S00_N1"
                },
                {
                    "id": "S00_N1",
                    "type": "dialogue",
                    "speaker": "{PC_NAME}",
                    "text": "It's fine. Nearby, the hospital where my dad used to work is around here too. So, two birds with one stone.",
                    "next": "S00_N2"
                },
                {
                    "id": "S00_N2",
                    "type": "dialogue",
                    "speaker": "{NPC_NAME}",
                    "text": "Yeah. That hospital... it's closed down now, though.",
                    "next": "S00_N3"
                },
                {
                    "id": "S00_N3",
                    "type": "interaction",
                    "target": "Abandoned Hospital : Main Entrance",
                    "whenInteract": [
                        {
                            "type": "branch",
                            "conditions": [{ "flagNot": "hospital_locked_checked" }],
                            "then": [
                                { "type": "setFlag", "flag": "hospital_locked_checked", "value": true },
                                {
                                "type": "narration",
                                "text": "The doorknob doesn't budge. A rusty padlock is hanging from it."
                                },
                                { "type": "dialogue", "speaker": "{PC_NAME}", "text": "It's locked... Let's check it later.", "next": "S00_N4" }
                            ],
                            "else": [
                                { "type": "narration", "text": "It's still locked." },
                                { "type": "dialogue", "speaker": "{PC_NAME}", "text": "Not right now.", "next": "S00_N4" }
                            ]
                        }
                    ]
                },
                {
                    "id": "S00_N4",
                    "type": "uiObjective",
                    "text": "Head to the ossuary"
                }
            ]
        },
        {
            "id": "S01_OSSUARY_INSIDE",
            "name": "The Ossuary",
            "nodes": [
                {
                    "id": "S01_N0",
                    "type": "dialogue",
                    "speaker": "{NPC_NAME}",
                    "text": "Dad... I'm here.",
                    "next": "S01_N1"
                },
                {
                    "id": "S01_N1",
                    "type": "action",
                    "do": [{ "type": "emote", "target": "{NPC_NAME}", "name": "placeFlowers" }],
                    "next": "S01_N2"
                },
                {
                    "id": "S01_N2",
                    "type": "dialogue",
                    "speaker": "{PC_NAME}",
                    "text": "...He passed away at... thirty... something. That's so young.",
                    "next": "S01_N3"
                },
                {
                    "id": "S01_N3",
                    "type": "dialogue",
                    "speaker": "{NPC_NAME}",
                    "text": "Yeah. So it feels even more like... time stopped back then.",
                    "next": "S01_N4"
                },
                {
                    "id": "S01_N4",
                    "type": "dialogue",
                    "speaker": "{PC_NAME}",
                    "text": "{NPC_FIRSTNAME}... are you okay?",
                    "next": "S01_N5"
                },
                {
                    "id": "S01_N5",
                    "type": "dialogue",
                    "speaker": "{NPC_NAME}",
                    "text": "...I'm going to step outside for some air. I'll be right back.",
                    "effects": [
                        { "type": "setFlag", "flag": "npc_missing", "value": true }
                    ],
                    "next": "S01_N6"
                },
                {
                    "id": "S01_N6",
                    "type": "timeSkip",
                    "seconds": 6,
                    "text": "A little time passes...",
                    "next": "S01_N7"
                },
                {
                    "id": "S01_N7",
                    "type": "dialogue",
                    "speaker": "{PC_NAME}",
                    "text": "Why is he taking so long...? I should go look for him."
                }
            ]
        },

        {
            "id": "S02_HOSPITAL_LOBBY",
            "name": "Abandoned Hospital Part 1 - Lobby (Reception Desk)",
            "onEnter": [
                { "type": "uiObjective", "text": "Search the hospital for {NPC_NAME}." }
            ],
            "nodes": [
                {
                    "id": "S02_N0",
                    "type": "narration",
                    "text": "The smell of dust, a lingering trace of disinfectant. Your footsteps echo..."
                },
                {
                    "id": "S02_N1",
                    "type": "pickup",
                    "itemId": "BUSINESS_CARD"
                },
                {
                    "id": "S02_N2",
                    "type": "uiObjective",
                    "text": "Head to the patient waiting room",
                    "nextScene": "S03_WAITING_ROOM"
                }
            ]
        },
        {
            "id": "S03_WAITING_ROOM",
            "name": "Part 1 - Patient Waiting Room",
            "nodes": [
                {
                    "id": "S03_N0",
