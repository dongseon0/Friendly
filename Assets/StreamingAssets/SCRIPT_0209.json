        {
            "id": "S10_RETURN_OFFICE_SAFE",
            "name": "Conclusion - 1F Office (Safe / Decisive Evidence)",
            "nodes": [
                {
                    "id": "S10_N0",
                    "type": "interaction",
                    "target": "Locked Safe",
                    "whenInteract": [
                        {
                        "type": "branch",
                        "conditions": [{ "flag": "ending_ready" }],
